---
import SectionTitle from '../components/SectionTitle.astro';

const skills = ['ROS2', 'C++', 'Python', 'LiDAR', 'SLAM', 'Embedded Systems', 'Computer Vision'];
---

<section id="about" class="mx-auto max-w-5xl px-6 py-24">
  <SectionTitle index="01" title="About" />
  <div class="space-y-4 text-light-slate">
    <p>
      I’m a robotics engineer focused on designing autonomous systems that can perceive, plan,
      and act in uncertain environments.
    </p>
    <p>
      My work combines robust software architecture with practical field testing, from sensor
      fusion and SLAM pipelines to embedded control loops and deployment-ready tooling.
    </p>
    <p>Technologies I work with most often:</p>
    <ul class="grid grid-cols-2 gap-y-2 font-mono text-sm text-lightest-slate sm:grid-cols-3">
      {skills.map((skill) => <li class="before:mr-2 before:text-accent before:content-['▹']">{skill}</li>)}
    </ul>
  </div>
</section>
