---
import SectionTitle from '../components/SectionTitle.astro';
---

<section id="contact" class="mx-auto max-w-3xl px-6 py-24 text-center">
  <SectionTitle index="04" title="Contact" />
  <h3 class="text-4xl font-bold text-lightest-slate">Get In Touch</h3>
  <p class="mx-auto mt-4 max-w-xl text-light-slate">
    Open to robotics collaborations and research opportunities.
  </p>
  <div class="mt-8 flex flex-wrap items-center justify-center gap-4 font-mono text-sm">
    <a href="mailto:pavan.patil.robotics@gmail.com" class="rounded border border-accent px-4 py-2 text-accent hover:-translate-y-1 hover:bg-accent/10">Email</a>
    <a href="https://github.com/" target="_blank" rel="noreferrer" class="rounded border border-lightest-navy px-4 py-2 text-lightest-slate hover:-translate-y-1 hover:border-accent hover:text-accent">GitHub</a>
    <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer" class="rounded border border-lightest-navy px-4 py-2 text-lightest-slate hover:-translate-y-1 hover:border-accent hover:text-accent">LinkedIn</a>
  </div>
</section>
