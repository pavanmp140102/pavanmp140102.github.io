---
import SectionTitle from '../components/SectionTitle.astro';
import IconFolder from '../components/IconFolder.astro';
import IconGithub from '../components/IconGithub.astro';

const projects = [
  {
    title: 'Autonomous Rescue Robot',
    description: 'Multi-sensor rescue platform with real-time mapping, victim detection, and adaptive mission planning.',
    tech: 'ROS2 | C++ | Python | LiDAR',
    github: 'https://github.com/',
  },
  {
    title: 'Robot Perception Stack',
    description: 'Camera and LiDAR perception stack for object tracking, terrain classification, and robust obstacle avoidance.',
    tech: 'ROS2 | OpenCV | SLAM',
    github: 'https://github.com/',
  },
  {
    title: 'Swarm Control Dashboard',
    description: 'Web-based operator dashboard for monitoring and controlling a fleet of collaborative mobile robots.',
    tech: 'Python | Embedded Systems | WebSockets',
    github: 'https://github.com/',
  },
];
---

<section id="work" class="mx-auto max-w-6xl px-6 py-24">
  <SectionTitle index="03" title="Work" />
  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    {projects.map((project) => (
      <article class="group rounded bg-light-navy p-6 shadow-glow transition hover:-translate-y-2 hover:shadow-xl">
        <div class="mb-6 flex items-center justify-between text-accent">
          <IconFolder />
          <a href={project.github} target="_blank" rel="noreferrer" class="hover:-translate-y-0.5"><IconGithub /></a>
        </div>
        <h3 class="text-xl font-semibold text-lightest-slate">{project.title}</h3>
        <p class="mt-3 text-light-slate">{project.description}</p>
        <p class="mt-4 font-mono text-sm text-slate">{project.tech}</p>
      </article>
    ))}
  </div>
</section>
