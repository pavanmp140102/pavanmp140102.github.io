---
import { getCollection } from 'astro:content';
import SectionTitle from '../components/SectionTitle.astro';

const projects = await getCollection('projects');
---

<section id="work" class="mx-auto max-w-6xl px-6 py-24">
  <SectionTitle index="03" title="Work" />
  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    {projects.map((project) => (
      <article class="group overflow-hidden rounded bg-light-navy shadow-glow transition hover:-translate-y-2 hover:shadow-xl">
        <img src={project.data.image} alt={project.data.title} class="h-44 w-full object-cover opacity-85 transition group-hover:opacity-100" />
        <div class="space-y-3 p-5">
          <h3 class="text-xl font-semibold text-lightest-slate">{project.data.title}</h3>
          <p class="text-light-slate">{project.data.description}</p>
          <p class="font-mono text-sm text-slate">{project.data.tech}</p>
          <a href={project.data.github} target="_blank" rel="noreferrer" class="font-mono text-sm text-accent hover:underline">
            GitHub →
          </a>
        </div>
      </article>
    ))}
  </div>
</section>
