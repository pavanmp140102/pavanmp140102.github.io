---
import { getCollection } from 'astro:content';
import SectionTitle from '../components/SectionTitle.astro';

const blogs = (await getCollection('blogs')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<section id="blog" class="mx-auto max-w-5xl px-6 py-24">
  <SectionTitle index="04" title="Blog" />
  <div class="space-y-4">
    {blogs.length === 0 ? (
      <p class="text-light-slate">More posts coming soon...</p>
    ) : (
      blogs.slice(0, 5).map((post) => (
        <article class="group rounded bg-light-navy p-5 shadow-glow transition hover:-translate-y-1">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <a href={`/blog/${post.slug}`} class="text-xl font-semibold text-lightest-slate hover:text-accent transition">
                {post.data.title}
              </a>
              <p class="mt-1 font-mono text-sm text-slate">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
              <p class="mt-2 text-light-slate">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="inline-block rounded bg-lighter-navy px-2 py-1 font-mono text-xs text-accent">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <a href={`/blog/${post.slug}`} class="font-mono text-sm text-accent hover:underline whitespace-nowrap">
              Read →
            </a>
          </div>
        </article>
      ))
    )}
  </div>
  {blogs.length > 5 && (
    <div class="mt-8 text-center">
      <a href="/blog" class="inline-block rounded px-6 py-3 font-mono text-sm text-accent hover:bg-light-navy transition">
        View all posts →
      </a>
    </div>
  )}
</section>
