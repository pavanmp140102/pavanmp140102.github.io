---
import { getCollection } from 'astro:content';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SectionTitle from '../../components/SectionTitle.astro';

const blogs = (await getCollection('blogs')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Blog | Pavan Patil</title>
  </head>
  <body>
    <Navbar />
    <main class="mx-auto max-w-4xl px-6 py-24">
      <SectionTitle index="Blog" title="All Posts" />
      <div class="space-y-6 mt-8">
        {blogs.map((post) => (
          <article class="group rounded bg-light-navy p-6 shadow-glow transition hover:-translate-y-1">
            <a href={`/blog/${post.slug}`} class="text-2xl font-semibold text-lightest-slate hover:text-accent transition">
              {post.data.title}
            </a>
            <p class="mt-2 font-mono text-sm text-slate">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
            <p class="mt-3 text-light-slate">{post.data.description}</p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="inline-block rounded bg-lighter-navy px-3 py-1 font-mono text-xs text-accent">
                    {tag}
                  </span>
                ))}
              </div>
            )}
            <a href={`/blog/${post.slug}`} class="mt-4 inline-block font-mono text-sm text-accent hover:underline">
              Read full post →
            </a>
          </article>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
